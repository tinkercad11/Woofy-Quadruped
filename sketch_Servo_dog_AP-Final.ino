void checkForNewCommand() {
  WiFiClient client = server.available();
  if (client) {
    while (!client.available()) {
      delay(1);
    }
    String request = client.readStringUntil('\r');
    client.flush();
    if (request.indexOf("GET") != -1) {
      request.remove(0, 5);
      request.remove(request.length() - 9, 9);
      x = request.toInt();
      if (x > 0) {
        y = x; // Update the command state
        Serial.println("Command updated to: " + String(y));
      }
    }
    client.stop();
  }
}


void blinking() {

  if   (counter > Blink) {
    counter = 0;
    display.clearDisplay();
    display.drawBitmap(0, 0,  bitmap_open, 128, 64, SH110X_WHITE, SH110X_BLACK);
    display.display();
    delay(50);

    display.clearDisplay();
    display.drawBitmap(0, 0,  bitmap_half, 128, 64, SH110X_WHITE, SH110X_BLACK);
    display.display();
    delay(50);

    display.clearDisplay();
    display.drawBitmap(0, 0,  bitmap_closed, 128, 64, SH110X_WHITE, SH110X_BLACK);
    display.display();
    delay(100);

    display.clearDisplay();
    display.drawBitmap(0, 0,  bitmap_half, 128, 64, SH110X_WHITE, SH110X_BLACK);
    display.display();
