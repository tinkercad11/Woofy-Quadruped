void setup()
{
  Serial.begin(9600);  // initialize the OLED object
  delay(1000); // wait for the OLED to power up
  display.begin(i2c_Address, true);
  /* Initialise the library and set it to 'servo mode' */
  a.Init(SERVO_MODE);
  b.Init(SERVO_MODE);
  c.Init(SERVO_MODE);
  d.Init(SERVO_MODE);

  /* Wake the device up */


  a.Sleep(false);
  b.Sleep(false);
  c.Sleep(false);
  d.Sleep(false);
  display.clearDisplay();
  display.display();
  WiFi.disconnect();
  ClientRequest = "";
  WiFi.softAP("RoboDog", "1234");
  delay(500);

  Serial.print("AP IP Address: ");
  Serial.println(WiFi.softAPIP());
  display.clearDisplay();
  display.setTextSize(2 / 1.05);
  display.setTextColor(SH110X_WHITE);
  display.setCursor(20, 0);
  display.println("Connected! IP :");
  display.setCursor(20, 30);
  display.println((WiFi.softAPIP().toString()));
  display.display();

  // Start the server
  server.begin();
  display.clearDisplay();
  display.drawBitmap(0, 0,  bitmap_open, 128, 64, SH110X_WHITE, SH110X_BLACK);
  display.display();

}


